{
	"compilerOptions": {
		"skipDefaultLibCheck": true,
		"target": "es2022",
		"verbatimModuleSyntax": true,
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"moduleResolution": "bundler",
		"module": "esnext",
		"noEmit": true,
		"lib": ["dom", "dom.iterable", "esnext"],
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"types": ["vite/client", "node"],
		"paths": {
			"@/*": ["./*"],
			"@octavian-tocan/react-dropdown": ["./lib/react-dropdown/src/index.ts"],
			"@octavian-tocan/react-dropdown/*": ["./lib/react-dropdown/src/*"]
		},
		"esModuleInterop": true
	},
	"include": [
		"vite-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		"**/*.mts",
		"src/routeTree.gen.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"lib/react-dropdown/src/__stories__",
		"lib/react-dropdown/src/__storybook__",
		"lib/react-dropdown/src/__tests__",
		"lib/react-dropdown/src/test-utils",
		"lib/react-dropdown/lostpixel.config.ts",
		"lib/react-dropdown/tsup.config.ts",
		"lib/react-dropdown/vitest.config.ts",
		"lib/react-dropdown/vitest.setup.ts"
	]
}
