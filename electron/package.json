{
	"name": "@ai-nexus/electron",
	"version": "0.1.0",
	"private": true,
	"description": "AI Nexus desktop shell — wraps the Next.js frontend in an Electron BrowserWindow.",
	"main": "dist/main.js",
	"scripts": {
		"dev": "tsc --watch --preserveWatchOutput",
		"build": "tsc",
		"start": "electron .",
		"start:dev": "ELECTRON_DEV=1 electron .",
		"dist": "bun run build && electron-builder",
		"dist:mac": "bun run build && electron-builder --mac",
		"dist:dir": "bun run build && electron-builder --dir"
	},
	"dependencies": {
		"electron-store": "^10.1.0",
		"wait-on": "^9.0.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@types/wait-on": "^5.3.4",
		"electron": "^33.2.0",
		"electron-builder": "^25.1.8",
		"typescript": "^5.9.3"
	},
	"build": {
		"appId": "ai.nexus.desktop",
		"productName": "AI Nexus",
		"directories": {
			"buildResources": "build",
			"output": "dist-app"
		},
		"files": [
			"dist/**/*",
			"package.json"
		],
		"extraResources": [
			{
				"from": "../frontend/.next/standalone",
				"to": "frontend",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "../frontend/.next/static",
				"to": "frontend/.next/static",
				"filter": [
					"**/*"
				]
			},
			{
				"from": "../frontend/public",
				"to": "frontend/public",
				"filter": [
					"**/*"
				]
			}
		],
		"mac": {
			"category": "public.app-category.productivity",
			"target": [
				{
					"target": "dmg",
					"arch": [
						"arm64",
						"x64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"arm64",
						"x64"
					]
				}
			],
			"hardenedRuntime": false,
			"gatekeeperAssess": false
		},
		"win": {
			"target": [
				"nsis"
			]
		},
		"linux": {
			"target": [
				"AppImage"
			],
			"category": "Office"
		}
	}
}
