{
	"name": "ai-nexus",
	"version": "0.1.0",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run dev.ts",
		"commit": "bun run commit.ts",
		"lint:policies": "bun run check-policies.mjs",
		"lint:file-lines": "node scripts/check-file-lines.mjs",
		"design:lint": "bunx @google/design.md lint DESIGN.md",
		"design:diff": "bunx @google/design.md diff",
		"design:export:css": "bunx @google/design.md export --format css-tailwind DESIGN.md"
	},
	"devDependencies": {
		"@google/design.md": "^0.1.1",
		"@tanstack/react-query-devtools": "^5.100.8",
		"@types/bun": "latest",
		"mcporter": "^0.9.0"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"workspaces": [
		"frontend",
		"electron"
	]
}
