# AI Nexus Backend Configuration
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED
# ===========================================

# JWT Secret Key for authentication
# Generate with: openssl rand -hex 32
AUTH_SECRET=your-super-secret-jwt-key-here

# Google Gemini API Key for LLM
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here

# ===========================================
# OPTIONAL
# ===========================================

# Environment mode: 'dev' or 'prod'
# - dev: cookies without Secure flag (allows http)
# - prod: cookies with Secure flag (requires https)
ENV=dev

# Database URL (defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./agno.db

# CORS allowed origins (defaults to localhost:3001)
CORS_ORIGINS=["http://localhost:3001","http://ai-nexus.localhost:1355"]

# Generate it once with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
FERNET_KEY=your-base64-key-here

# ===========================================
# REGISTRATION GATE
# ===========================================

# When set, new accounts can only be created by supplying this value as
# "invite_code" in the registration request body.
# Leave empty (or omit) to allow open registration.
# Generate with: openssl rand -hex 16
REGISTRATION_SECRET=
