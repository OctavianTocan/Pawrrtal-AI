{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false
	},
	"overrides": [
		{
			"includes": ["frontend/components/ui/**"],
			"linter": { "enabled": false },
			"formatter": { "enabled": false },
			"assist": { "enabled": false }
		},
		{
			"includes": ["frontend/components/craft-ui/**"],
			"linter": { "enabled": false },
			"formatter": { "enabled": false },
			"assist": { "enabled": false }
		},
		{
			"includes": [
				"frontend/lib/craft-shared/**",
				"frontend/lib/craft-core-stubs.ts",
				"frontend/components/shell/**",
				"frontend/components/chat/**",
				"frontend/components/input/**",
				"frontend/components/icons/**",
				"frontend/components/browser/**",
				"frontend/components/settings/**",
				"frontend/components/info/**",
				"frontend/components/apisetup/**",
				"frontend/components/automations/**",
				"frontend/components/workspace/**",
				"frontend/components/onboarding/**",
				"frontend/components/shiki/**",
				"frontend/components/markdown/**",
				"frontend/components/right-sidebar/**",
				"frontend/components/files/**",
				"frontend/components/AppMenu.tsx",
				"frontend/components/ServerDirectoryBrowser.tsx",
				"frontend/components/KeyboardShortcuts.tsx",
				"frontend/components/KeyboardShortcutsDialog.tsx",
				"frontend/components/SplashScreen.tsx",
				"frontend/components/ResetConfirmationDialog.tsx",
				"frontend/context/**",
				"frontend/contexts/**",
				"frontend/actions/**",
				"frontend/config/**",
				"frontend/utils/**",
				"frontend/pages/**",
				"frontend/hooks/useSession.ts",
				"frontend/hooks/useSessionActions.ts",
				"frontend/hooks/useSessionSearch.ts",
				"frontend/hooks/useSessionOptions.ts",
				"frontend/hooks/useTurnCardExpansion.ts",
				"frontend/hooks/useTheme.ts",
				"frontend/hooks/useResizablePanels.ts",
				"frontend/hooks/useMultiSelect.ts",
				"frontend/hooks/useEntitySelection.ts",
				"frontend/hooks/useEntityListInteractions.ts",
				"frontend/hooks/useBackgroundTasks.ts",
				"frontend/hooks/useStatuses.ts",
				"frontend/hooks/useLabels.ts",
				"frontend/hooks/useViews.ts",
				"frontend/hooks/useLinkInterceptor.ts",
				"frontend/hooks/useDirectoryPicker.ts",
				"frontend/hooks/useResizeGradient.ts",
				"frontend/hooks/useHorizontalResizeGradient.ts",
				"frontend/hooks/useNotifications.ts",
				"frontend/hooks/useDynamicStack.ts",
				"frontend/hooks/useTransportConnectionState.ts",
				"frontend/hooks/useStaleSessionRecovery.ts",
				"frontend/hooks/useUpdateChecker.ts",
				"frontend/hooks/useWindowCloseHandler.ts",
				"frontend/hooks/useOnboarding.ts",
				"frontend/hooks/useWorkspaceIcon.ts",
				"frontend/hooks/useAutomations.ts",
				"frontend/hooks/keyboard/**",
				"frontend/lib/animations.ts",
				"frontend/lib/platform.ts",
				"frontend/lib/local-storage.ts",
				"frontend/lib/mentions.ts",
				"frontend/lib/navigate.ts",
				"frontend/lib/navigation-registry.ts",
				"frontend/lib/overlay-detection.ts",
				"frontend/lib/perf.ts",
				"frontend/lib/provider-icons.ts",
				"frontend/lib/slugify.ts",
				"frontend/lib/smart-typography.ts",
				"frontend/lib/merge-refs.ts",
				"frontend/lib/file-utils.ts",
				"frontend/lib/icon-cache.ts",
				"frontend/lib/skill-mentions.ts",
				"frontend/lib/logger.ts",
				"frontend/lib/reconnect-recovery.ts",
				"frontend/lib/dismissible-layer-bridge.ts",
				"frontend/atoms/craft-sessions.ts",
				"frontend/atoms/overlay.ts",
				"frontend/atoms/panel-stack.ts",
				"frontend/atoms/sources.ts",
				"frontend/atoms/skills.ts",
				"frontend/atoms/browser-pane.ts",
				"frontend/atoms/automations.ts"
			],
			"linter": { "enabled": false },
			"formatter": { "enabled": false },
			"assist": { "enabled": false }
		}
	],
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
